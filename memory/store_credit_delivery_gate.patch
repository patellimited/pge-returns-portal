+async def deactivate_coupon(cfg: Dict[str, str], *, code: str) -> bool:
+    """Deactivate a WooCommerce coupon by setting its expiry to yesterday.
+
+    Returns True on success, False on any failure (including the coupon not
+    being found). Safe to call multiple times. Used by the admin "Revoke
+    store credit" button when a parcel arrives empty/damaged and the coupon
+    should no longer be redeemable.
+    """
+    store = (cfg.get("wc_store_url") or "").rstrip("/")
+    key = cfg.get("wc_consumer_key") or ""
+    secret = cfg.get("wc_consumer_secret") or ""
+    if not store or not key or not secret or not code:
+        return False
+
+    # 1) Look up the coupon by code to get its id.
+    try:
+        async with httpx.AsyncClient(timeout=20.0) as client:
+            r = await client.get(
+                f"{store}/wp-json/wc/v3/coupons",
+                auth=(key, secret),
+                params={"code": code},
+            )
+        if r.status_code != 200:
+            return False
+        rows = r.json() or []
+        if not rows:
+            return False
+        coupon_id = rows[0].get("id")
+        if not coupon_id:
+            return False
+    except Exception:
+        return False
+
+    # 2) Expire it. We set both `date_expires` (yesterday) and `usage_limit`
+    #    to whatever it's already used — this stops any further redemptions.
+    from datetime import datetime as _dt, timedelta as _td, timezone as _tz
+    yesterday = (_dt.now(_tz.utc) - _td(days=1)).date().isoformat()
+    try:
+        async with httpx.AsyncClient(timeout=20.0) as client:
+            r = await client.put(
+                f"{store}/wp-json/wc/v3/coupons/{coupon_id}",
+                auth=(key, secret),
+                json={
+                    "date_expires": yesterday,
+                    # Also set usage_limit to its current usage_count so if
+                    # the coupon has already been used once, it can't be
+                    # redeemed again, and if it hasn't, it's capped at 0.
+                    "usage_limit": int(rows[0].get("usage_count") or 0),
+                    "description": (rows[0].get("description") or "")
+                                   + " [REVOKED]",
+                },
+            )
+        return r.status_code in (200, 201)
+    except Exception:
+        return False
